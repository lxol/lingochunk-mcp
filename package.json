{
  "name": "@lingochunk/mcp",
  "version": "0.6.1",
  "description": "Model Context Protocol server for the LingoChunk public API: your FSRS-graded vocabulary, native-audio transcripts and clips, and library, as tools for a coding agent.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "bin": {
    "lingochunk-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "smoke": "node --experimental-strip-types scripts/smoke.ts",
    "validate:lesson": "node --experimental-strip-types scripts/validate-lesson.ts",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ajv": "^8.20.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lingochunk/lingochunk-mcp.git"
  },
  "homepage": "https://github.com/lingochunk/lingochunk-mcp#readme",
  "bugs": {
    "url": "https://github.com/lingochunk/lingochunk-mcp/issues"
  }
}
